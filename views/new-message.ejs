<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>New Message - Inner Circle</title>
  <link rel="stylesheet" href="/css/output.css">
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-900 via-gray-900 to-black flex items-center justify-center px-4 text-gray-200">

  <div class="w-full max-w-2xl bg-white/5 backdrop-blur-lg border border-white/10 rounded-2xl shadow-2xl p-8">

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white mb-2">Create a Message</h1>
      <p class="text-gray-400 text-sm">
        Share something with the Inner Circle community.
      </p>
    </div>

    <!-- Form -->
    <form action="/messages/new" method="POST" class="space-y-6">

      <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">
          Your Message
        </label>
        <textarea 
          name="content" 
          required
          rows="5"
          class="w-full rounded-xl bg-gray-800 border border-gray-700 px-4 py-3 text-white resize-none focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
          placeholder="Write your message here..."
        ></textarea>
      </div>

      <% if (user.role === "member") { %>
        <div class="flex items-center space-x-3 bg-indigo-500/10 border border-indigo-500/30 rounded-lg p-3">
          <input 
            type="checkbox" 
            name="isMemberOnly"
            class="w-4 h-4 text-indigo-600 bg-gray-800 border-gray-600 rounded focus:ring-indigo-500"
          >
          <label class="text-sm text-indigo-300 font-medium">
            Make this message members-only
          </label>
        </div>
      <% } %>

      <!-- Buttons -->
      <div class="flex justify-between items-center">

        <a 
          href="/messages"
          class="text-gray-400 hover:text-white transition text-sm"
        >
          ← Back to Messages
        </a>

        <button 
          type="submit"
          class="bg-indigo-600 hover:bg-indigo-500 text-white px-6 py-2.5 rounded-xl font-semibold shadow-lg shadow-indigo-600/20 transition duration-200"
        >
          Post Message
        </button>

      </div>

    </form>

  </div>

</body>
</html>