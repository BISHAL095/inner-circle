<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Upgrade to Member - Inner Circle</title>
  <link rel="stylesheet" href="/css/output.css">
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-900 via-gray-900 to-black flex items-center justify-center px-4 text-gray-200">

  <div class="w-full max-w-md bg-white/5 backdrop-blur-lg border border-white/10 rounded-2xl shadow-2xl p-8">

    <!-- Header -->
    <div class="mb-6 text-center">
      <h2 class="text-3xl font-bold text-white mb-2">
        Unlock Membership
      </h2>
      <p class="text-gray-400 text-sm">
        Enter the secret code to access exclusive content.
      </p>
    </div>

    <% if (error) { %>
      <div class="mb-6 bg-red-500/10 border border-red-500/30 text-red-300 px-4 py-3 rounded-lg text-sm text-center">
        <%= error %>
      </div>
    <% } %>

    <!-- Form -->
    <form action="/upgrade" method="POST" class="space-y-6">

      <div>
        <label 
          for="secretCode" 
          class="block text-sm font-medium text-gray-300 mb-2"
        >
          Secret Code
        </label>

        <input 
          type="password" 
          name="secretCode" 
          id="secretCode" 
          required
          class="w-full rounded-xl bg-gray-800 border border-gray-700 px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
          placeholder="Enter your code..."
        />
      </div>

      <button 
        type="submit"
        class="w-full bg-indigo-600 hover:bg-indigo-500 text-white py-3 rounded-xl font-semibold shadow-lg shadow-indigo-600/20 transition duration-200"
      >
        Upgrade to Member
      </button>

    </form>

    <!-- Footer -->
    <div class="mt-6 text-center">
      <a 
        href="/" 
        class="text-sm text-gray-400 hover:text-white transition"
      >
        ← Back to Home
      </a>
    </div>

  </div>

</body>
</html>